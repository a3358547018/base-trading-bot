# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_TOKEN=8649380601:AAEKO_XF3Df8Ic1I7KG8P8sgiCjgTgdJ_c8

# 你的 Telegram ID（仅此用户可控制机器人）
# 获取方式：发送 /id 给 @userinfobot
